@font-face {
  font-family: "Roboto";
  src: url("{{ 'roboto-regular-webfont.woff2' | file_url }}") format("woff2");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: "Roboto";
  src: url("{{ 'roboto-medium-webfont.woff2' | file_url }}") format("woff2");
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}
.font-brand {
  font-family: "Roboto", system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
}