{%- comment -%}
  Domaine Product Card
  Usage:
    {% render 'product-card-domaine', card_product: product %}

  Shows:
    - On sale badge + markdown pricing
    - Title
    - Variant color swatches
{%- endcomment -%}

{%- if card_product and card_product != empty -%}
  {%- assign product = card_product -%}
  {%- assign variant = product.selected_or_first_available_variant -%}

  {%- assign on_sale = false -%}
  {%- if variant.compare_at_price and variant.compare_at_price > variant.price -%}
    {%- assign on_sale = true -%}
  {%- endif -%}

  {%- assign featured_media = product.featured_media -%}
  {%- if variant.featured_media -%}
    {%- assign featured_media = variant.featured_media -%}
  {%- endif -%}

  {%- comment -%} Compute initial hover image url (variant metafield fallback) {%- endcomment -%}
  {%- assign hover_image_url = '' -%}
  {%- if variant.metafields.custom.secondary_image != blank -%}
    {%- assign hover_image_url = variant.metafields.custom.secondary_image | image_url: width: 600 -%}
  {%- elsif product.media.size > 1 -%}
    {%- assign hover_image_url = product.media[1] | image_url: width: 600 -%}
  {%- endif -%}

  <div class="w-full max-w-[320px]" data-product-card>
    <div class="flex flex-col">
      <a href="{{ product.url }}" class="block">
        <div class="relative">
          <span
            data-sale-badge
            class="{%- unless on_sale -%} hidden {%- endunless -%} font-brand absolute left-3 top-3 z-10 inline-flex rounded-full border border-[#FF0000] bg-white px-3 text-[15px] font-normal text-[#FF0000]"
          >
            On Sale!
          </span>

          <div class="group aspect-square overflow-hidden rounded-lg border border-[#E8E8E8] p-4 relative">
            {%- if featured_media -%}
              <img
                data-primary-image
                src="{{ featured_media.preview_image| image_url: width: 600 }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
                width="{{ featured_media.preview_image.width }}"
                height="{{ featured_media.preview_image.height }}"
                class="absolute inset-0 h-full w-full object-contain transition-opacity duration-200 group-hover:opacity-0"
              >

              <img
                data-hover-image
                src="{{ hover_image_url }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
                width="{{ featured_media.preview_image.width }}"
                height="{{ featured_media.preview_image.height }}"
                class="absolute inset-0 h-full w-full object-contain opacity-0 transition-opacity duration-200 group-hover:opacity-100 {%- if hover_image_url == blank -%} hidden{%- endif -%}"
              >
            {%- else -%}
              <div class="flex h-full w-full items-center justify-center text-sm text-gray-400">No image</div>
            {%- endif -%}
          </div>
        </div>
      </a>

      {%- comment -%} Swatches {%- endcomment -%}
      {%- assign color_option_index = null -%}
      {%- for opt in product.options_with_values -%}
        {%- if opt.name == 'color' or opt.name == 'Color' or opt.name == 'Colour' -%}
          {%- assign color_option_index = forloop.index0 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if color_option_index != null -%}
        <div class="mt-3 flex items-center gap-2" data-product-card-swatches>
          {%- for v in product.variants -%}
            {%- assign color_value = v.options[color_option_index] -%}

            {%- comment -%} Compute per variant primary image url {%- endcomment -%}
            {%- assign v_img = product.featured_media -%}
            {%- if v.featured_media -%}
              {%- assign v_img = v.featured_media -%}
            {%- endif -%}
            {%- assign v_img_url = v_img | image_url: width: 600 -%}

            {%- comment -%} Compute per variant hover image url  {%- endcomment -%}
            {%- assign v_hover_url = '' -%}
            {%- if v.metafields.custom.secondary_image != blank -%}
              {%- assign v_hover_url = v.metafields.custom.secondary_image | file_url -%}
            {%- elsif product.media.size > 1 -%}
              {%- assign v_hover_url = product.media[1] | image_url: width: 900 -%}
            {%- endif -%}

            {%- comment -%} Per variant sale flag {%- endcomment -%}
            {%- assign v_on_sale = false -%}
            {%- if v.compare_at_price and v.compare_at_price > v.price -%}
              {%- assign v_on_sale = true -%}
            {%- endif -%}

            {%- comment -%} Selected state for initial variant {%- endcomment -%}
            <button
              type="button"
              class="
                h-[22px] w-[22px] rounded-full border p-[2px]
                hover:border-[#0A4874] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#0A4874]
                {% if v.id == variant.id %}border-[#0A4874]{% else %}border-transparent{% endif %}
              "
              title="{{ color_value | escape }}"
              aria-label="Select {{ color_value | escape }}"
              aria-pressed="{%- if v.id == variant.id -%}true{%- else -%}false{%- endif -%}"

              data-swatch
              data-variant-id="{{ v.id }}"
              data-color="{{ color_value | escape }}"

              data-image="{{ v_img_url }}"
              data-hover-image="{{ v_hover_url }}"
              data-price="{{ v.price | money | escape }}"
              data-compare-at="{% if v.compare_at_price %}{{ v.compare_at_price | money | escape }}{% endif %}"
              data-on-sale="{% if v_on_sale %}true{% else %}false{% endif %}"
            >
              <span
                class="block h-full w-full rounded-full"
                style="background-color: {{ color_value | downcase }};"
              ></span>
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="mt-3">
        <div class="font-brand text-[14px] font-normal text-[#111111]">
          {{ product.vendor }}
        </div>
        <div class="font-brand font-medium text-[16px] text-[#0A4874]">
          {{ product.title }}
        </div>

        <div class="flex items-baseline gap-3">
          <span
            data-compare-at-display
            class="text-[14px] text-[#111111] line-through {%- unless on_sale -%} hidden{%- endunless -%}"
          >
            {{ variant.compare_at_price | money }}
          </span>

          <span
            data-price-display
            class="text-[14px] font-normal{% if on_sale %} text-[#FF0000]{% else %} text-[#111111]{% endif %}"
          >
            {{ variant.price | money }}
          </span>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}
